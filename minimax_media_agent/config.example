{
  "MINIMAX_API_KEY": "MiniMax Platform API key (required). Get one from https://platform.minimax.io/user-center/basic-information/interface-key",
  "MINIMAX_API_BASE": "Base URL for the MiniMax API. Global: https://api.minimax.io (default). Mainland China: https://api.minimaxi.com",
  "LLM_MODEL": "Model used for the planning / tool-loop LLM. Options: MiniMax-M2.7 (default), MiniMax-M2.7-highspeed, MiniMax-M2.5, MiniMax-M2.5-highspeed, MiniMax-M2.1, MiniMax-M2.1-highspeed, MiniMax-M2",
  "LLM_MAX_TOKENS": "Maximum tokens per LLM response (default: 4096)",
  "LLM_TEMPERATURE": "LLM sampling temperature, range (0, 1]. Recommended: 1.0",
  "IMAGE_MODEL": "MiniMax image-generation model id (default: image-01)",
  "SPEECH_MODEL": "Default MiniMax speech model. Options: speech-2.8-hd (default), speech-2.8-turbo, speech-2.6-hd, speech-2.6-turbo, speech-02-hd, speech-02-turbo. The LLM may override per call via the tool's `model` parameter.",
  "SPEECH_POLL_INTERVAL": "Seconds between polls of the async T2A task status (default: 3)",
  "SPEECH_MAX_WAIT": "Maximum seconds to wait for an async T2A task to complete before giving up (default: 600 = 10 minutes)",
  "MUSIC_MODEL": "Default MiniMax music model. Options: music-2.6 (default, paid tier, higher RPM), music-2.6-free (free tier, lower RPM), music-cover (paid tier, cover generation), music-cover-free (free tier cover). The LLM may override per call via the tool's `model` parameter. Use the -free variants if your API key is not on a paid plan.",
  "VIDEO_MODEL": "Default MiniMax video model used for text-to-video and image-to-video. Options include MiniMax-Hailuo-2.3 (default), MiniMax-Hailuo-02 (used automatically for first-last-frame mode), S2V-01 (used automatically for subject-reference mode). The LLM may override per call via the tool's `model` parameter.",
  "VIDEO_POLL_INTERVAL": "Seconds between polls of the video_generation task status (default: 10). MiniMax recommends 10s to avoid unnecessary server load.",
  "VIDEO_MAX_WAIT": "Maximum seconds to wait for a video task to complete before giving up (default: 1800 = 30 minutes). Video generation is much slower than audio.",
  "OUTPUT_DIR": "Directory where generated media files are written. Blank = agents/minimax_media_agent/data/output",
  "AGENT_TIMEOUT": "Overall timeout (seconds) for a single LLM turn including tool execution (default: 180)",
  "HTTP_TIMEOUT": "Timeout (seconds) for each outbound MiniMax HTTP call (default: 120)",
  "MAX_ITERATIONS": "Maximum LLM tool-loop iterations (default: 6)",
  "MAX_TOOL_CALLS": "Maximum total tool calls across all iterations (default: 8)",
  "ALLOWED_USER_IDS": "Allowlist of user_ids permitted to invoke this agent. MiniMax media APIs are billed per call so access is deny-by-default. Supply a JSON array of user_ids, e.g. [\"alice\", \"bob\"]. Use [\"*\"] to allow any caller that supplies a user_id. Empty list denies everyone."
}
